
#Область ПрограммныйИнтерфейс

// Получает значение реквизита объекта по ссылке без загрузки всего объекта.
// Выполняет точечный запрос к базе данных.
//
// Параметры:
//  Ссылка         - ЛюбаяСсылка - ссылка на объект, реквизит которого нужно получить.
//  ИмяРеквизита   - Строка      - имя реквизита (может содержать точку для вложенных реквизитов, например "Контрагент.ИНН").
//
// Возвращаемое значение:
//  Произвольный - значение запрошенного реквизита. 
//                 Фактический тип соответствует типу реквизита в метаданных.
//                 Если реквизит не найден или ссылка пустая - Неопределено.
//
// Пример:
//  // Для реквизита "Валюта" типа СправочникСсылка.Валюты
//  ВалютаСчета = ПолучитьЗначениеРеквизита(Счет, "Валюта"); // вернет СправочникСсылка.Валюты
//
Функция ПолучитьЗначениеРеквизита(Ссылка, ИмяРеквизита) Экспорт

    // Проверка на пустую ссылку
    Если Не ЗначениеЗаполнено(Ссылка) Или Не ЗначениеЗаполнено(ИмяРеквизита) Тогда
        Возврат Неопределено;
    КонецЕсли;

    // Получаем полное имя таблицы (Документ.ИмяДокумента, Справочник.ИмяСправочника и т.д.)
    ПолноеИмяТаблицы = Ссылка.Метаданные().ПолноеИмя();
    
    // Формируем текст запроса
    ТекстЗапроса = 
    "ВЫБРАТЬ РАЗРЕШЕННЫЕ
    |    %1 КАК ЗначениеРеквизита
    |ИЗ
    |    %2 КАК Таблица
    |ГДЕ
    |    Таблица.Ссылка = &Ссылка";
    
    // Подставляем имя реквизита и имя таблицы
    ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяРеквизита, ПолноеИмяТаблицы);
    
    // Создаем и выполняем запрос
    Запрос = Новый Запрос;
    Запрос.Текст = ТекстЗапроса;
    Запрос.УстановитьПараметр("Ссылка", Ссылка);
    
    Результат = Запрос.Выполнить().Выбрать();
    
    Если Результат.Следующий() Тогда
        Возврат Результат.ЗначениеРеквизита;
    КонецЕсли;
    
    Возврат Неопределено;

КонецФункции

// Получает структуру со значениями нескольких реквизитов объекта по ссылке.
// Выполняет один запрос к базе данных для всех указанных реквизитов.
//
// Параметры:
//  Ссылка               - ЛюбаяСсылка - ссылка на объект.
//  МассивИменРеквизитов - Массив из Строка - массив строк с именами реквизитов.
//                                       Имена могут содержать точку для вложенных реквизитов.
//
// Возвращаемое значение:
//  Структура - структура, где ключи соответствуют именам реквизитов,
//              а значения - полученным данным. Если реквизит не найден или ссылка пустая,
//              соответствующее поле структуры будет содержать Неопределено.
//
// Пример:
//  Реквизиты = Новый Массив;
//  Реквизиты.Добавить("Валюта");
//  Реквизиты.Добавить("Дата");
//  Реквизиты.Добавить("Контрагент.ИНН");
//  Значения = ЗначенияРеквизитов(СсылкаНаДокумент, Реквизиты);
//  Сообщить(Значения.Валюта);
//  Сообщить(Значения.Контрагент.ИНН); // Обратите внимание: доступ через точку, как в структуре
//
Функция ПолучитьЗначенияРеквизитов(Ссылка, МассивИменРеквизитов) Экспорт

    Результат = Новый Структура;
    
    // Если ссылка пустая, возвращаем пустую структуру
    Если Не ЗначениеЗаполнено(Ссылка) Тогда
        Возврат Результат;
    КонецЕсли;
    
    // Если список реквизитов пуст, делать нечего
    Если МассивИменРеквизитов.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    // Формируем список полей для запроса
    ПоляДляЗапроса = "";
    Для Каждого ИмяРеквизита Из МассивИменРеквизитов Цикл
        // Защита от дурака (убираем лишние пробелы)
        ИмяРеквизита = СокрЛП(ИмяРеквизита);
        Если ПустаяСтрока(ИмяРеквизита) Тогда
            Продолжить;
        КонецЕсли;
        
        // Добавляем поле в список
        Если Не ПустаяСтрока(ПоляДляЗапроса) Тогда
            ПоляДляЗапроса = ПоляДляЗапроса + ",";
        КонецЕсли;
        
        // Используем имя реквизита как псевдоним для удобства
        ПоляДляЗапроса = ПоляДляЗапроса + " " + ИмяРеквизита + " КАК [" + ИмяРеквизита + "]";
    КонецЦикла;
    
    ПолноеИмяТаблицы = Ссылка.Метаданные().ПолноеИмя();
    
    ТекстЗапроса = 
    "ВЫБРАТЬ РАЗРЕШЕННЫЕ
    |    %1
    |ИЗ
    |    %2 КАК Таблица
    |ГДЕ
    |    Таблица.Ссылка = &Ссылка";
    
    ТекстЗапроса = СтрШаблон(ТекстЗапроса, ПоляДляЗапроса, ПолноеИмяТаблицы);
    
    Запрос = Новый Запрос;
    Запрос.Текст = ТекстЗапроса;
    Запрос.УстановитьПараметр("Ссылка", Ссылка);
    
    Выборка = Запрос.Выполнить().Выбрать();
    
    Если Выборка.Следующий() Тогда
        Для Каждого ИмяРеквизита Из МассивИменРеквизитов Цикл
            ИмяРеквизита = СокрЛП(ИмяРеквизита);
            Если ПустаяСтрока(ИмяРеквизита) Тогда
                Продолжить;
            КонецЕсли;
            
            // Заполняем структуру значениями из выборки
            Результат.Вставить(ИмяРеквизита, Выборка[ИмяРеквизита]);
        КонецЦикла;
    КонецЕсли;
    
    Возврат Результат;

КонецФункции

